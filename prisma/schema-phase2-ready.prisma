// ================================================
// SUPPLIER SCORING
// ================================================

model SupplierScore {
  id                String   @id @default(uuid())
  supplierId        String   @unique
  organizationId    String
  
  // Overall score
  totalScore        Int      // 0-100
  rating            String   // excellent (80-100), good (60-79), medium (40-59), poor (0-39)
  trend             String   // improving, stable, declining
  
  // Individual metric scores (0-100 each)
  deliveryScore     Int      @default(50)
  priceStabilityScore Int    @default(50)
  qualityScore      Int      @default(50)
  issueScore        Int      @default(50)
  communicationScore Int     @default(50)
  refundScore       Int      @default(50)
  
  // Raw statistics for calculation
  totalOrders       Int      @default(0)
  avgDeliveryDays   Float?
  priceVariancePercent Float?
  returnRatePercent Float?
  issuesCount       Int      @default(0)
  avgResponseHours  Float?
  refundRatePercent Float?
  
  lastCalculated    DateTime @default(now())
  nextCalculation   DateTime?
  
  organization      Organization @relation(fields: [organizationId], references: [id])
  supplier          Supplier @relation(fields: [supplierId], references: [id])
  history           SupplierScoreHistory[]
  
  @@index([organizationId])
  @@index([supplierId])
  @@index([totalScore])
  @@index([rating])
}

model SupplierScoreHistory {
  id                String   @id @default(uuid())
  supplierScoreId   String
  
  totalScore        Int
  deliveryScore     Int
  priceStabilityScore Int
  qualityScore      Int
  issueScore        Int
  communicationScore Int
  refundScore       Int
  
  calculatedAt      DateTime @default(now())
  
  score             SupplierScore @relation(fields: [supplierScoreId], references: [id], onDelete: Cascade)
  
  @@index([supplierScoreId])
  @@index([calculatedAt])
}

